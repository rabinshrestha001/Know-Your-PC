:root {
    --primary-blue: #38bdf8;
    --dark-bg: #0b1120;
    --dark-section: #1e293b;
    --light-bg: #f0f9ff;
    --white: #ffffff;
    --text-main: #334155;
    --text-light: #94a3b8;
    --accent-orange: #f97316;
    --accent-green: #22c55e;
    --accent-purple: #a855f7;
    --font-main: 'Inter', sans-serif;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: var(--font-main);
    color: var(--text-main);
    background-color: var(--white);
    line-height: 1.6;
}

a {
    text-decoration: none;
    color: inherit;
}

ul {
    list-style: none;
}

/* Navbar */
.navbar {
    background-color: var(--white);
    position: sticky;
    top: 0;
    z-index: 1000;
    border-bottom: 1px solid #e2e8f0;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
}

.nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1rem;
}

.logo {
    display: flex;
    align-items: center;
    gap: 10px;
}

.logo i {
    font-size: 1.5rem;
    background: #0ea5e9;
    color: white;
    padding: 8px;
    border-radius: 6px;
}

.logo-text h3 {
    font-size: 1rem;
    color: #0f172a;
    margin-bottom: -2px;
}

.logo-text span {
    font-size: 0.7rem;
    color: #64748b;
}

.nav-links {
    display: flex;
    gap: 2rem;
}

.nav-links a {
    font-size: 0.9rem;
    color: #475569;
    font-weight: 500;
    transition: 0.3s;
}

.nav-links a:hover {
    color: var(--primary-blue);
}

/* Hero Section */
.hero {
    background-color: var(--dark-bg);
    color: white;
    padding: 4rem 5%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
    min-height: 600px;
}

.hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -20%;
    width: 80%;
    height: 200%;
    background: radial-gradient(circle, rgba(56, 189, 248, 0.1) 0%, rgba(0, 0, 0, 0) 60%);
    z-index: 0;
}

.hero-content {
    flex: 1;
    z-index: 2;
    max-width: 500px;
}

.hero h1 {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1rem;
}

.hero .highlight {
    color: var(--primary-blue);
}

.hero p {
    color: #cbd5e1;
    margin-bottom: 2rem;
    font-size: 1.1rem;
}

.hero-buttons {
    display: flex;
    gap: 1rem;
}

.btn {
    padding: 12px 24px;
    border-radius: 50px;
    font-weight: 600;
    cursor: pointer;
    border: none;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: 0.3s;
}

.btn-primary {
    background-color: var(--primary-blue);
    color: #0f172a;
}

.btn-primary:hover {
    background-color: #7dd3fc;
}

.btn-outline {
    background: transparent;
    border: 1px solid white;
    color: white;
}

.btn-outline:hover {
    background: rgba(255, 255, 255, 0.1);
}

/* Hero Image & Tags */
.hero-image-container {
    flex: 1;
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
}

.hero-img {
    width: 100%;
    max-width: 450px;
    filter: drop-shadow(0 0 20px rgba(56, 189, 248, 0.3));
    mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
}

.tag {
    position: absolute;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    color: white;
    font-weight: 600;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
}

.tag-cpu {
    top: 20%;
    left: 10%;
    background: var(--primary-blue);
}

.tag-gpu {
    bottom: 20%;
    left: 20%;
    background: var(--accent-purple);
}

.tag-ram {
    top: 40%;
    right: 5%;
    background: var(--accent-green);
}

.tag-storage {
    bottom: 30%;
    right: 20%;
    background: var(--accent-orange);
}

/* Quick Cards */
.quick-cards {
    padding: 4rem 5%;
    background: var(--white);
}

.container {
    max-width: 1200px;
    margin: 0 auto;
}

.quick-cards .container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
}

.card {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    border: 1px solid #f1f5f9;
    transition: 0.3s;
    position: relative;
}

.card:hover {
    transform: translateY(-5px);
}

.icon-circle {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    margin-bottom: 1rem;
    font-size: 1.2rem;
}

.card h3 {
    margin-bottom: 0.5rem;
    color: #1e293b;
}

.card p {
    font-size: 0.9rem;
    color: #64748b;
    margin-bottom: 1rem;
}

.card-arrow {
    position: absolute;
    bottom: 2rem;
    right: 2rem;
    color: #cbd5e1;
    font-size: 0.9rem;
}

.blue {
    background: var(--primary-blue);
}

.orange {
    background: var(--accent-orange);
}

.green {
    background: var(--accent-green);
}

.indigo {
    background: #4f46e5;
}

/* Why Matters */
.why-matters {
    padding: 4rem 5%;
}

.split-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
}

.text-side h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: #0f172a;
}

.underline-blue {
    border-bottom: 4px solid var(--primary-blue);
}

.subtitle {
    color: #64748b;
    margin-bottom: 3rem;
}

.feature-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
}

.feature-item {
    display: flex;
    gap: 15px;
}

.f-icon {
    background: var(--primary-blue);
    color: white;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.feature-item h4 {
    font-size: 1rem;
    margin-bottom: 4px;
}

.feature-item p {
    font-size: 0.8rem;
    color: #64748b;
    line-height: 1.4;
}

.image-side img {
    width: 100%;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
}

/* Dark Components Section */
.dark-info {
    background: #1e293b;
    color: white;
    padding: 5rem 5%;
}

.section-header {
    text-align: center;
    margin-bottom: 3rem;
}

.section-header h2 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
}

.section-header p {
    color: #94a3b8;
    margin-bottom: 2rem;
}

.toggle-pill {
    background: #334155;
    display: inline-flex;
    padding: 5px;
    border-radius: 30px;
}

.toggle-pill button {
    background: transparent;
    border: none;
    color: #cbd5e1;
    padding: 8px 24px;
    border-radius: 25px;
    cursor: pointer;
    font-weight: 500;
}

.toggle-pill button.active {
    background: var(--primary-blue);
    color: #0f172a;
}

.components-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.comp-card {
    background: #2a3649;
    padding: 1.5rem;
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: 0.3s;
}

.comp-card:hover {
    background: #334155;
}

.comp-icon {
    width: 45px;
    height: 45px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
}

.c-blue {
    background: rgba(56, 189, 248, 0.2);
    color: var(--primary-blue);
}

.c-green {
    background: rgba(34, 197, 94, 0.2);
    color: var(--accent-green);
}

.c-orange {
    background: rgba(249, 115, 22, 0.2);
    color: var(--accent-orange);
}

.c-purple {
    background: rgba(168, 85, 247, 0.2);
    color: var(--accent-purple);
}

.comp-text h3 {
    font-size: 1.1rem;
    margin-bottom: 2px;
}

.comp-text p {
    font-size: 0.8rem;
    color: #94a3b8;
}

.quick-tip {
    background: #2d3748;
    border: 1px solid #4a5568;
    padding: 1.5rem;
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
}

.bulb {
    width: 40px;
    height: 40px;
    background: #eab308;
    color: #0f172a;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.quick-tip h4 {
    color: #eab308;
    font-size: 0.9rem;
    margin-bottom: 2px;
}

.quick-tip p {
    font-size: 0.9rem;
    color: #cbd5e1;
}

/* Top Tips & Slider (UPDATED) */
.top-tips {
    background: #f0f9ff;
    padding: 4rem 5%;
    text-align: center;
}

.top-tips h2 {
    color: #0f172a;
    font-size: 2rem;
}

.sub-center {
    color: #64748b;
    margin-bottom: 3rem;
}

.quote-slider {
    background: white;
    max-width: 800px;
    margin: 0 auto 3rem;
    padding: 3rem 4rem;
    /* Increased padding for quotes */
    border-radius: 20px;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
    position: relative;
    min-height: 250px;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

/* Updated Quote Icon Styling */
.quote-icon {
    color: #67e8f9;
    /* Cyan color from image */
    font-size: 2.5rem;
    position: absolute;
    opacity: 0.8;
}

.left-q {
    top: 20px;
    left: 20px;
}

.right-q {
    top: 20px;
    right: 20px;
}

.quote-content h3 {
    font-weight: 500;
    color: #334155;
    margin: 1rem 0;
    font-size: 1.3rem;
    transition: opacity 0.5s ease-in-out;
}

.slider-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: auto;
}

.arrow {
    background: #f1f5f9;
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    transition: 0.2s;
    color: #475569;
}

.arrow:hover {
    background: #e2e8f0;
}

.dots {
    display: flex;
    gap: 6px;
}

.dot {
    width: 8px;
    height: 8px;
    background: #cbd5e1;
    border-radius: 50%;
    cursor: pointer;
    transition: 0.3s;
}

.dot.active {
    background: #0ea5e9;
    width: 24px;
    border-radius: 12px;
}

.tip-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
}

.tip-card {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    text-align: center;
}

.tip-icon {
    width: 50px;
    height: 50px;
    margin: 0 auto 1rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
}

.tip-card:nth-child(1) .tip-icon {
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
}

.tip-card:nth-child(2) .tip-icon {
    background: rgba(56, 189, 248, 0.1);
    color: #38bdf8;
}

.tip-card:nth-child(3) .tip-icon {
    background: rgba(168, 85, 247, 0.1);
    color: #a855f7;
}

/* Resources */
.resources {
    padding: 4rem 5%;
    text-align: center;
}

.resource-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
}

.res-card {
    padding: 3rem;
    border-radius: 20px;
    text-align: left;
}

.pink-bg {
    background: linear-gradient(135deg, #fdf4ff 0%, #fae8ff 100%);
}

.blue-bg {
    background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
}

.res-icon {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    margin-bottom: 1.5rem;
}

.pink-bg .res-icon {
    background: #d946ef;
}

.blue-bg .res-icon {
    background: #0ea5e9;
}

.res-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: #1e293b;
}

.res-card p {
    color: #64748b;
    margin-bottom: 2rem;
}

.res-link {
    color: #c026d3;
    font-weight: 600;
    font-size: 0.9rem;
}

.blue-bg .res-link {
    color: #0284c7;
}

/* Footer */
footer {
    background: #0f172a;
    color: white;
    padding-top: 4rem;
}

.footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #1e293b;
}

.footer-desc {
    color: #94a3b8;
    margin-top: 1rem;
    font-size: 0.9rem;
    max-width: 300px;
}

.footer-col h4 {
    margin-bottom: 1.5rem;
    font-size: 1rem;
}

.footer-col ul li {
    margin-bottom: 0.8rem;
}

.footer-col ul li a {
    color: #94a3b8;
    font-size: 0.9rem;
    transition: 0.3s;
}

.footer-col ul li a:hover {
    color: var(--primary-blue);
}

.socials {
    display: flex;
    gap: 1rem;
}

.socials a {
    width: 35px;
    height: 35px;
    background: #1e293b;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 0.9rem;
    transition: 0.3s;
}

.socials a:hover {
    background: var(--primary-blue);
    color: #0f172a;
}

.copyright {
    padding: 2rem 5%;
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: #64748b;
}

/* Tab Logic */
.tab-content {
    display: none;
}

.tab-content.active {
    display: block;
    animation: fadeIn 0.4s ease;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.grid-2 {
    grid-template-columns: repeat(2, 1fr) !important;
    max-width: 900px;
    margin: 0 auto 2rem;
}

/* Gradient Cards for Types & Purpose */
.type-card {
    padding: 2rem !important;
}

.comp-icon-large {
    font-size: 2rem;
    color: white;
    width: 60px;
    height: 60px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 1.5rem;
}

.purple-grad .comp-icon-large {
    background: linear-gradient(135deg, #a855f7, #7e22ce);
}

.orange-grad .comp-icon-large {
    background: linear-gradient(135deg, #f97316, #ea580c);
}

.blue-grad .comp-icon-large {
    background: linear-gradient(135deg, #06b6d4, #0891b2);
}

.pink-grad .comp-icon-large {
    background: linear-gradient(135deg, #ec4899, #db2777);
}

/* Responsive */
@media (max-width: 900px) {

    .hero,
    .split-layout,
    .components-grid,
    .tip-cards,
    .resource-grid,
    .footer-grid {
        grid-template-columns: 1fr;
        flex-direction: column;
        text-align: center;
    }

    .hero-content {
        margin-bottom: 3rem;
    }

    .hero-buttons {
        justify-content: center;
    }

    .split-layout {
        gap: 2rem;
    }

    .footer-col {
        text-align: center;
    }

    .socials {
        justify-content: center;
    }
}